# Never commit DEPLOYER_PRIVATE_KEY or MNEMONIC. Keep them only in .env.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
BASE_SEPOLIA_LEVEL_PRICE_ETH=0.0001

# Revenue and retained project funds.
PROJECT_WALLET=0xeF9B7b298f821124c6c81D21e1cD99966a331a5A
TREASURY_ADDRESS=0xeF9B7b298f821124c6c81D21e1cD99966a331a5A
SKILL_TREASURY_ADDRESS=0xeF9B7b298f821124c6c81D21e1cD99966a331a5A

# Use separate operational addresses for administration and round signing.
OPERATOR_WALLET=0xYourOperatorAddress
ADMIN_OWNER_ADDRESS=0xYourAdminOrMultisigAddress
SCHEDULE_SIGNER_ADDRESS=0xYourOfflineScheduleSignerAddress

# Optional guard against deploying from the wrong signer.
EXPECTED_DEPLOYER_ADDRESS=0xYourDeployerAddress
