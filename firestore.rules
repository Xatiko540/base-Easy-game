rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Public levels — read without auth, write only via Admin SDK
    match /levels/{levelId} {
      allow read: if true;
      allow write: if false;
    }

    // Signed season manifests and round schedules. Client writes are denied;
    // publication is performed only by the trusted Admin SDK path.
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if false;
    }

    match /rounds/{roundId} {
      allow read: if true;
      allow write: if false;

      match /winningCells/{cellId} {
        // Winning leaves remain private until trusted settlement publishes a
        // separate immutable reveal document.
        allow read, write: if false;
      }
    }

    match /roundReveals/{roundId} {
      allow read: if true;
      allow write: if false;
    }

    // Global aggregated stats — public read
    match /stats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Public wallet profiles contain on-chain/public data only. Firebase UID
    // remains isolated in walletLinks and is never copied into these docs.
    match /users/{userId} {
      allow read: if true;
      allow write: if false;

      match /levels/{levelId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Events — public read
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // Transactions — only own uid
    match /transactions/{transactionId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Verified Base Pay orders. Only the linked Firebase user can inspect its
    // fulfillment status; all writes are performed through Admin SDK.
    match /basePayPayments/{paymentId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // Wallet links — only own uid
    match /walletLinks/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
